# ── Required: transcription ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Required: AI smart cuts (/api/analyze-cuts) ─────────────────────────────
INCEPTION_API_KEY=your_inception_api_key

# ── Required: upload + export (AWS / Remotion Lambda) ─────────────────────────
REMOTION_AWS_REGION=us-east-1
REMOTION_AWS_ACCESS_KEY_ID=your_aws_access_key
REMOTION_AWS_SECRET_ACCESS_KEY=your_aws_secret_key
REMOTION_S3_BUCKET=remotionlambda-xxxxx
REMOTION_FUNCTION_NAME=remotion-render-xxx
REMOTION_SERVE_URL=https://your-bucket.s3.us-east-1.amazonaws.com/sites/expound

# ── Optional: AI chat, B-roll, frame analysis ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_API_KEY=          # alias for GEMINI_API_KEY

# ── Optional: audio enhancement ─────────────────────────────────────────────
CLEANVOICE_API_KEY=your_cleanvoice_api_key

# ── Optional: video generation (Runway; falls back to Gemini Veo) ───────────
RUNWAY_API_KEY=your_runway_api_key

# ── Legacy / unused on main ───────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
PEXELS_API_KEY=
